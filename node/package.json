{
  "name": "spicedb-embedded",
  "version": "0.7.0",
  "description": "Embedded SpiceDB for TypeScript/Node.js — embedded authorization using the standard gRPC API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "optionalDependencies": {
    "spicedb-embedded-linux-x64": "0.7.0",
    "spicedb-embedded-linux-arm64": "0.7.0",
    "spicedb-embedded-darwin-arm64": "0.7.0",
    "spicedb-embedded-win32-x64": "0.7.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run format:check"
  },
  "dependencies": {
    "@authzed/authzed-node": "^1.6.1",
    "@grpc/grpc-js": "^1.14.4",
    "koffi": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borkfork/spicedb-embedded.git"
  }
}
